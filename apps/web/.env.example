# Prismic
NEXT_PUBLIC_PRISMIC_ENVIRONMENT=tyrocoach

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://tyrocoach.com

# Prismic revalidation webhook secret
# Generate with: openssl rand -hex 32
REVALIDATION_SECRET=your-secret-here

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_RECTANGLE=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_SKYSCRAPER=XXXXXXXXXX
